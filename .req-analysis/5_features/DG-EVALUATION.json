      "capability": "강의평가를 등록할 수 있다",
      "trigger": {
        "actor": "student_user",
        "action": "POST /api/v1/evaluation/add"
      },
      "behavior": {
        "preconditions": [
          "유효한 세션이 있어야 한다",
          "Student 권한이 있어야 한다",
          "해당 강의에 승인된 수강신청(APPROVED)이 있어야 한다",
          "중복 평가가 없어야 한다"
        ],
        "postconditions": [
          "강의평가가 등록된다",
          "수강신청의 평가 완료 상태가 업데이트된다"
        ],
        "side_effects": [],
        "guard_failure": [
          "승인된 수강신청 없음 → 평가 불가",
          "중복 평가 → 오류 반환"
        ]
      },
