            "RU": "수업/필수",
            "EW": "워크숍/선택",
            "RW": "워크숍/필수",
            "EP": "프로젝트/선택",
            "RP": "프로젝트/필수"
          },
          "semester": {
            "SPRING": "봄",
            "FALL": "가을"
          }
        },
        "validation_messages": [],
        "disabled_conditions": [],
        "confirmation_guard": null,
        "polling": null
      },
      "evidence_refs": [
