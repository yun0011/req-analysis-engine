    {
      "feature_id": "FR-LECTURE-001",
      "capability": "개설수업을 등록할 수 있다",
      "trigger": {
        "actor": "admin_user",
        "action": "POST /api/v1/lecture/add"
      },
      "behavior": {
        "preconditions": [
          "유효한 세션이 있어야 한다",
          "Admin 권한이 있어야 한다"
        ],
        "postconditions": [
          "새 개설수업이 등록된다"
        ],
        "side_effects": [
          "해당 학기가 존재하지 않으면 자동으로 READY 상태로 생성된다"
        ],
        "guard_failure": []
      },
      "field_constraints": [
        "교과목(courseID)은 등록 후 변경할 수 없다",
        "담당 스승(userID)은 등록 후 변경할 수 없다",
        "학기(year + semester)는 등록 후 변경할 수 없다"
      ],
      "ui": {
        "display_fields": [
          "id",
          "course",
          "user",
          "category",
          "term",
          "classroom",
          "limit",
          "schedule"
        ],
        "display_labels": {
